---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-2xl mx-auto px-6 py-20 font-sans selection:bg-sky-500/30">
    
    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-serif text-[#f8fafc] mb-4 tracking-tight">
        Antonio Javier Rázuri
      </h1>
      <p class="text-xl text-[#38bdf8] font-medium tracking-wide uppercase text-sm">
        Freelance Web Developer & Business Consultant
      </p>
    </header>

    <section class="space-y-6 text-[#94a3b8] text-lg leading-relaxed">
      <p>
        Director y fundador de <span class="text-[#f8fafc] font-semibold">Síncope: Estudio Digital</span>. 
        Mi enfoque híbrido combina la precisión de la contabilidad con la arquitectura del desarrollo web 
        para construir modelos de negocio optimizados.
      </p>
      
      <p>
        Basado en <span class="text-[#f8fafc]">Santiago de Surco, Lima</span>, me especializo en soluciones 
        eCommerce y Product Management, transformando ideas técnicas en herramientas estratégicas.
      </p>
    </section>

    <section class="mt-16 pt-8 border-t border-slate-800">
      <h3 class="font-serif text-[#f8fafc] text-2xl mb-6">Proyectos y Enfoque</h3>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="text-[#38bdf8]">🟢</span>
          <span><strong class="text-slate-200">Síncope:</strong> Branding, Web Dev & eCommerce.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[#38bdf8]">🟢</span>
          <span><strong class="text-slate-200">Metodología:</strong> Estructura financiera + Código limpio.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[#38bdf8]">🟡</span>
          <span><strong class="text-slate-200">Explorando:</strong> Data Science e IA (Cibertec 2027).</span>
        </li>
      </ul>
    </section>

    <footer class="mt-20">
      <a 
        href="mailto:tu-correo@ejemplo.com" 
        class="inline-block bg-[#38bdf8] hover:bg-sky-400 text-[#0f172a] font-bold py-4 px-10 rounded-full transition-all active:scale-95"
      >
        Hablemos de tu proyecto
      </a>
    </footer>

  </main>
</Layout>

<style>
  /* Importamos una Serif elegante para los títulos */
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@600&family=Inter:wght@400;500;600&display=swap');

  h1, h2, h3 {
    font-family: 'Crimson Pro', serif;
  }
  
  p, span, li, a {
    font-family: 'Inter', sans-serif;
  }
</style>