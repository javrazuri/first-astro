---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col items-center justify-center min-h-screen bg-slate-900 text-white p-6">
    
    <h1 class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-emerald-400 mb-4">
      ¡Despegue Exitoso! 🚀
    </h1>

    <p class="text-xl text-slate-400 max-w-md text-center">
      Este es mi nuevo estudio de programación. <span class="text-sky-300 font-bold">Astro + Tailwind</span> funcionando en mi Mac.
    </p>

    <button class="mt-8 px-6 py-3 bg-sky-600 hover:bg-sky-500 rounded-full font-bold transition-all shadow-lg shadow-sky-500/20">
      Mi primer botón interactivo
    </button>

  </main>
</Layout>